{
  "title": "Vigil Input",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "company_name": {
      "title": "Company Name",
      "type": "string",
      "description": "Name of the company",
      "editor": "textfield"
    },
    "industry": {
      "title": "Industry",
      "type": "string",
      "description": "Industry sector",
      "editor": "textfield"
    },
    "country": {
      "title": "Country",
      "type": "string",
      "description": "Country code (e.g. DE, PL)",
      "editor": "textfield"
    },
    "size": {
      "title": "Company Size",
      "type": "string",
      "description": "startup / sme / enterprise",
      "editor": "textfield"
    },
    "areas_of_concern": {
      "title": "Regulatory Areas",
      "type": "array",
      "description": "List of regulations to monitor",
      "editor": "stringList"
    },
    "test_mode": {
      "title": "Test Mode",
      "type": "boolean",
      "description": "Use fewer pages for faster/cheaper runs",
      "editor": "checkbox",
      "default": true
    }
  },
  "required": ["company_name", "industry", "country"]
}