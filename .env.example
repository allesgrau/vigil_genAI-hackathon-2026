# Apify – get your token at https://console.apify.com/account/integrations
APIFY_TOKEN=your_apify_token_here

# OpenRouter via Apify Standby Actor
OPENROUTER_ACTOR_URL=https://openrouter.apify.actor/api/v1

# Twilio – get credentials at https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+12603773910

# SendGrid – create API key at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=your_verified_email@example.com

# Server URLs
SERVER_URL=https://your-ngrok-url.ngrok.io
APP_URL=https://vigil-demo.streamlit.app